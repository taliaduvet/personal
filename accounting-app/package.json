{
  "name": "ledger-accounting-app",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint app.js api.js js/ledger-pure.js js/ledger-bank.js js/parse-csv.js js/ledger-constants.js js/ui-helpers.js js/ledger-api-helpers.js",
    "qa:full": "npm run test && npm run e2e",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:headed:slow": "PW_HEADED_SLOW=1 playwright test --headed --workers=1",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:reuse": "PW_REUSE_SERVER=1 playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
