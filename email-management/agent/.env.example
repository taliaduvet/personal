# Gmail OAuth — run OAuth flow once, then paste refresh_token here
GMAIL_REFRESH_TOKEN=
# Or use credentials.json (download from Google Cloud Console) — client_id/secret loaded from there
# Path to credentials.json (default: same dir as triage.py)
# GMAIL_CREDENTIALS_PATH=./credentials.json

# Supabase (same as parking lot app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Gemini API — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Parking lot config
PARKING_LOT_PAIR_ID=solo_default
PARKING_LOT_CATEGORY_PRESET=generic
